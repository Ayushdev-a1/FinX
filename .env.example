# paper | live
TRADING_MODE=paper

# Comma-separated instrument list (used when dynamic stock picker is disabled)
SYMBOLS=RELIANCE.NS,TATASTEEL.NS,HDFCBANK.NS

# Loop interval
POLL_INTERVAL_MS=15000

# Risk and portfolio controls
INITIAL_CAPITAL=1000000
MAX_POSITION_PCT=0.05
MAX_LOSS_PER_TRADE_PCT=0.01
MAX_DAILY_DRAWDOWN_PCT=0.03
MAX_SECTOR_EXPOSURE_PCT=0.2

# Optional data APIs
POLYGON_API_KEY=
NEWS_API_KEY=

# Angel One broker credentials (required for live mode)
# Get these from https://smartapi.angelone.in/
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=
ANGEL_ONE_JWT_TOKEN=
ANGEL_ONE_REFRESH_TOKEN=

# Dynamic stock picker (auto-discovers best stocks for intraday)
ENABLE_DYNAMIC_STOCK_PICKER=true
STOCK_PICKER_MIN_VOLUME=500000
STOCK_PICKER_MIN_PRICE=50
STOCK_PICKER_MAX_PRICE=5000
STOCK_PICKER_MAX_STOCKS=10

# Self-learning system (learns from trade outcomes to improve signals)
ENABLE_SELF_LEARNING=true
LEARNING_DATA_PATH=./data/learning

# AI-powered signal analysis (optional)
GEMINI_API_KEY=
# Model name for your OpenAI-compatible provider (default: llama-3.3-70b-versatile on Groq)
GEMINI_MODEL=llama-3.3-70b-versatile

# HTTP monitoring server port (optional, e.g. 3000)
AGENT_HTTP_PORT=8000
