# paper | live
TRADING_MODE=paper

# Comma-separated instrument list
SYMBOLS=RELIANCE.NS,TATASTEEL.NS,HDFCBANK.NS

# Loop interval
POLL_INTERVAL_MS=15000

# Risk and portfolio controls
INITIAL_CAPITAL=1000000
MAX_POSITION_PCT=0.05
MAX_LOSS_PER_TRADE_PCT=0.01
MAX_DAILY_DRAWDOWN_PCT=0.03
MAX_SECTOR_EXPOSURE_PCT=0.2

# Optional data APIs
POLYGON_API_KEY=
NEWS_API_KEY=

# Required only for live mode
ZERODHA_API_KEY=
ZERODHA_ACCESS_TOKEN=
